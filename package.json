{
  "name": "msft-icons-drawio",
  "version": "0.1.0",
  "description": "Generate draw.io (diagrams.net) shape libraries from official Microsoft product SVG icon sets (Azure, Fabric, Dynamics 365, Power Platform, Microsoft 365, Entra/Security).",
  "type": "module",
  "license": "MIT",
  "bin": {
    "msft-icons": "./dist/index.js"
  },
  "scripts": {
    "generate": "tsx src/index.ts build",
    "validate": "tsx src/validate.ts",
    "plugin": "tsx src/plugin.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "clean": "node -e \"require('fs').rmSync('tmp',{recursive:true,force:true})\""
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "fast-xml-parser": "^4.5.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  }
}
